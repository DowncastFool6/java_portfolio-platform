<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd">
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>pt.com.ctrl.vault.controller.RegisterController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>pt.com.ctrl.vault.controller.LoginController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>pt.com.ctrl.vault.controller.LogoutController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>pt.com.ctrl.vault.controller.DashboardController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/dashboard</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ProjetosServlet</servlet-name>
        <servlet-class>pt.com.ctrl.vault.controller.ProjetosController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProjetosServlet</servlet-name>
        <url-pattern>/projetos</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ProjetoDetalheServlet</servlet-name>
        <servlet-class>pt.com.ctrl.vault.controller.ProjetoDetalheController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProjetoDetalheServlet</servlet-name>
        <url-pattern>/projeto</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ProjetoNovoConteudoServlet</servlet-name>
        <servlet-class>pt.com.ctrl.vault.controller.ProjetoNovoConteudoController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProjetoNovoConteudoServlet</servlet-name>
        <url-pattern>/projeto/conteudos/novo</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ConteudoArquivoServlet</servlet-name>
        <servlet-class>pt.com.ctrl.vault.controller.ConteudoArquivoController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ConteudoArquivoServlet</servlet-name>
        <url-pattern>/conteudos/arquivo</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ProjetoUsuariosServlet</servlet-name>
        <servlet-class>pt.com.ctrl.vault.controller.ProjetoUsuariosController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProjetoUsuariosServlet</servlet-name>
        <url-pattern>/projeto/usuarios</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ContatoServlet</servlet-name>
        <servlet-class>pt.com.ctrl.vault.controller.ContatoController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ContatoServlet</servlet-name>
        <url-pattern>/contatos</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ContatosRecebidosServlet</servlet-name>
        <servlet-class>pt.com.ctrl.vault.controller.ContatosRecebidosController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ContatosRecebidosServlet</servlet-name>
        <url-pattern>/contatos/recebidos</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>AdminUsuariosServlet</servlet-name>
        <servlet-class>pt.com.ctrl.vault.controller.AdminUsuariosController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminUsuariosServlet</servlet-name>
        <url-pattern>/admin/usuarios</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>AdminUsuarioAcessoServlet</servlet-name>
        <servlet-class>pt.com.ctrl.vault.controller.AdminUsuarioAcessoController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminUsuarioAcessoServlet</servlet-name>
        <url-pattern>/admin/usuarios/acesso</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
    <!-- 404 – Not Found -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/error/error-404.jsp</location>
    </error-page>

    <!-- 403 – Forbidden -->
    <error-page>
        <error-code>403</error-code>
        <location>/WEB-INF/error/error-403.jsp</location>
    </error-page>

    <!-- 500 – Internal Server Error -->
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/error/error-500.jsp</location>
    </error-page>

    <!-- Catch-all for unhandled Java exceptions -->
    <error-page>
        <exception-type>java.lang.Exception</exception-type>
        <location>/WEB-INF/error/error-500.jsp</location>
    </error-page>
    <error-page>
        <error-code>401</error-code>
        <location>/login</location>
    </error-page>
</web-app>
